# ─────────────────────────────────────────────────────────────
# social-snap — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# All API keys are OPTIONAL.
# Without them the SDK still works — it falls back to
# oEmbed and Open Graph tags for title, author, and thumbnail.
# API keys are only needed to unlock engagement metrics
# (likes, views, comments, etc.)
#
# ⚠  Never commit your .env file to version control.
#    Make sure .env is listed in your .gitignore.
# ─────────────────────────────────────────────────────────────


# ── YouTube Data API v3 ───────────────────────────────────────
# Unlocks: view count, like count, comment count
# Get one at: https://console.cloud.google.com/
#   1. Create a project
#   2. Enable "YouTube Data API v3"
#   3. Create an API key under Credentials
YOUTUBE_API_KEY=


# ── Twitter / X API v2 ───────────────────────────────────────
# Unlocks: likes, reposts, replies, quotes, impressions
# Get one at: https://developer.twitter.com/
#   1. Create a project and app
#   2. Copy the Bearer Token from Keys & Tokens
TWITTER_BEARER=


# ── Instagram / Facebook Graph API ───────────────────────────
# Unlocks: oEmbed (author name, thumbnail) for Instagram posts
# Note: Instagram does NOT expose like/comment counts publicly
# Get one at: https://developers.facebook.com/
#   1. Create a Meta developer app
#   2. Add the oEmbed product
#   3. Generate a user or app access token
INSTAGRAM_TOKEN=


# ── Backend / Server Config ───────────────────────────────────
# Port your Express / backend server listens on
PORT=3000

# Origin of your frontend app — used to restrict the proxy
# endpoint's CORS header in production.
# In development you can leave this as * or http://localhost:5173
ALLOWED_ORIGIN=*